# ─────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores
# NUNCA suba o .env para o GitHub
# ─────────────────────────────────────────────

# Ambiente: development | production
ENV=production

# Tokens da API VHSYS (em: Configurações → API no painel)
VHSYS_ACCESS_TOKEN=seu_access_token_aqui
VHSYS_SECRET_TOKEN=seu_secret_token_aqui

# ── WhatsApp (Evolution API) ──────────────────────────────────
EVOLUTION_API_URL=http://SEU_IP:8080
EVOLUTION_API_KEY=sua_chave_aqui
EVOLUTION_INSTANCE=pablo-agro
WHATSAPP_NOTIFY_NUMBER=5534XXXXXXXXX
WHATSAPP_ENABLED=true

# ── Expedição VHSys ───────────────────────────────────────────
# Intervalo em minutos para verificar expedições no VHSys (padrão: 5)
EXPEDICAO_POLL_INTERVAL_MIN=5

# ── Módulo Compras / NF-e ─────────────────────────────────────
# Certificado digital A1 (.pfx ou .p12)
NFE_CERT_PATH=C:/mercos_vhsys_git/data/certs/empresa.pfx
NFE_CERT_SENHA=senha_do_certificado
# CNPJ da empresa (14 dígitos, sem formatação)
NFE_CNPJ_EMPRESA=00000000000000
# Ambiente SEFAZ: 1=Produção, 2=Homologação
NFE_AMBIENTE=1
# URL do webservice nfeDistDFe (varia por UF)
# Nacional (maioria das UFs): https://www1.nfe.fazenda.gov.br/NFeDistribuicaoDFe/NFeDistribuicaoDFe.asmx
# São Paulo: https://www.nfe.fazenda.sp.gov.br/nfeDistribuicaoDFe/NFeDistribuicaoDFe.asmx
SEFAZ_NFE_URL=https://www1.nfe.fazenda.gov.br/NFeDistribuicaoDFe/NFeDistribuicaoDFe.asmx
# Intervalos do scheduler (opcional, defaults abaixo)
COMPRAS_SEFAZ_INTERVAL_HORAS=1.5
COMPRAS_WORKER_INTERVAL_MIN=5

# ── Painel Admin ──────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=troque_esta_senha
